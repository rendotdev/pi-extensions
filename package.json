{
  "name": "@rendotdev/lgtm",
  "version": "0.2.2",
  "private": false,
  "description": "Human approval for agent work, with code diff and Markdown review.",
  "keywords": [
    "ai-agents",
    "code-review",
    "human-in-the-loop",
    "rendotdev"
  ],
  "homepage": "https://github.com/rendotdev/lgtm#readme",
  "bugs": {
    "url": "https://github.com/rendotdev/lgtm/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rendotdev/lgtm.git"
  },
  "bin": {
    "lgtm": "bin/lgtm.mjs"
  },
  "files": [
    ".agents/plugins/marketplace.json",
    ".claude-plugin",
    ".codex-plugin/plugin.json",
    ".mcp.claude.json",
    ".mcp.json",
    "bin",
    "dist/cli.mjs",
    "dist/web",
    "extensions",
    "skills",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "build": "vp build",
    "check": "vp check",
    "demo:images": "vp run demo:assets",
    "lgtm": "vp run lgtm:cli",
    "metadata:check": "vp run metadata:verify",
    "metadata:sync": "vp run metadata:write",
    "pack:dry": "vp run artifact:pack",
    "package": "vp run build:package",
    "prepack": "vp run artifact:prepare",
    "release:beta": "vp run release:beta:task",
    "release:major": "vp run release:major:task",
    "release:minor": "vp run release:minor:task",
    "release:patch": "vp run release:patch:task",
    "test": "vp test"
  },
  "dependencies": {
    "ink": "^7.1.0",
    "jsonc-parser": "^3.3.1",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@heroui/react": "^3.2.2",
    "@heroui/styles": "^3.2.2",
    "@pierre/diffs": "^1.2.12",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-form": "^1.33.1",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.5",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ink-testing-library": "^4.0.0",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "playwright": "^1.61.1",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "bun@1.3.14",
  "pi": {
    "extensions": [
      "extensions/index.js"
    ],
    "skills": [
      "skills"
    ]
  }
}
