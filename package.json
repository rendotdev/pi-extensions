{
  "name": "@rendotdev/lgtm",
  "version": "0.1.0",
  "private": false,
  "description": "Human approval for agent work, with code diff and Markdown review.",
  "keywords": [
    "ai-agents",
    "code-review",
    "human-in-the-loop",
    "rendotdev"
  ],
  "homepage": "https://github.com/rendotdev/lgtm#readme",
  "bugs": {
    "url": "https://github.com/rendotdev/lgtm/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rendotdev/lgtm.git"
  },
  "bin": {
    "lgtm": "dist/cli.mjs"
  },
  "files": [
    "README.md",
    "extensions/lgtm.ts",
    "dist",
    "src",
    "tsconfig.json"
  ],
  "type": "module",
  "scripts": {
    "lgtm": "node src/cli.ts",
    "pack:dry": "npm pack --dry-run",
    "prepack": "vp run package"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@heroui/react": "^3.2.2",
    "@heroui/styles": "^3.2.2",
    "@pierre/diffs": "^1.2.12",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-form": "^1.33.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "geist": "^1.7.2",
    "lucide-react": "^1.23.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "11.16.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "npm@11.16.0",
  "pi": {
    "extensions": [
      "extensions/lgtm.ts"
    ]
  }
}
